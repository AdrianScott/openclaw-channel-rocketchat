# Rocket.Chat test credentials (DO NOT COMMIT REAL VALUES)
ROCKETCHAT_BASE_URL=http://localhost:3000
ROCKETCHAT_AUTH_TOKEN=replace_me
ROCKETCHAT_USER_ID=replace_me

# Security Configuration (Optional - overrides defaults)
# Environment (development, production)
NODE_ENV=development

# Rate Limiting Settings
# API Rate Limiting (requests per minute)
SECURITY_API_RATE_LIMIT=1000
SECURITY_API_RATE_WINDOW_MS=60000

# WebSocket Rate Limiting (messages per window)
SECURITY_WS_RATE_LIMIT=300
SECURITY_WS_RATE_WINDOW_MS=10000

# File Upload Security
# Maximum file size in bytes (default: 10MB)
SECURITY_MAX_FILE_SIZE=10485760

# File validation settings (disabled by default - Rocket.Chat handles this)
SECURITY_ENABLE_MIME_TYPE_VALIDATION=false
SECURITY_ENABLE_MAGIC_NUMBER_VALIDATION=false

# WebSocket Security
# Comma-separated list of allowed origins
SECURITY_ALLOWED_ORIGINS=https://yourapp.com,https://*.yourapp.com

# Logging
# Security log level (error, warn, info, debug)
SECURITY_LOG_LEVEL=info
